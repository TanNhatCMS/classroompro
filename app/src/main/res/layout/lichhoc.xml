<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        tools:ignore="UselessParent">
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            tools:ignore="UselessLeaf" />
        <ScrollView
            android:layout_width="fill_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="16.0sp"
                    android:padding="8.0dip"
                    android:paddingLeft="16.0dip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" Buổi sáng"
                    tools:ignore="HardcodedText,RtlSymmetry"
                    app:drawableLeftCompat="@drawable/sang" />
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@id/list_item"
                    android:scrollbars="vertical"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content" />
                <TextView
                    android:textSize="16.0sp"
                    android:padding="8.0dip"
                    android:paddingLeft="16.0dip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" Buổi chiều"
                    app:drawableLeftCompat="@drawable/chieu" />
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/list_item2"
                    android:scrollbars="vertical"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content" />
                <TextView
                    android:textSize="16.0sp"
                    android:id="@+id/textView6"
                    android:padding="8.0dip"
                    android:paddingLeft="16.0dip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" Buổi tối"
                    app:drawableLeftCompat="@drawable/toi"
                    tools:ignore="RtlSymmetry" />
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/list_item3"
                    android:scrollbars="vertical"
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</LinearLayout>